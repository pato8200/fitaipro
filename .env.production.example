# FitAI Pro - Production Environment Variables
# IMPORTANT: Generate secure random values for all secrets before deploying to production!

# ============================================
# DATABASE CONFIGURATION
# ============================================
# For production, use PostgreSQL instead of SQLite for better performance
# SQLite (for testing/demo): DATABASE_URL="file:./dev.db"
# PostgreSQL (production): DATABASE_URL="postgresql://user:password@localhost:5432/fitai-pro"
DATABASE_URL="postgresql://username:password@localhost:5432/fitai-pro"

# ============================================
# JWT SECRETS - CRITICAL FOR SECURITY!
# ============================================
# Generate new secure random strings using: openssl rand -hex 32
# DO NOT use the default values in production!
JWT_SECRET="generate-new-secure-random-string-for-production"
JWT_REFRESH_SECRET="generate-another-secure-random-string-for-production"

# ============================================
# AI CONFIGURATION
# ============================================
# Option 1: Use Ollama (FREE, local LLM) - Recommended for cost savings
USE_OLLAMA=true
OLLAMA_BASE_URL="http://localhost:11434"

# Option 2: Use Hugging Face (has free tier, then pay-per-use)
# HUGGINGFACE_API_KEY="your-huggingface-api-key-here"

# Option 3: Use OpenAI (paid, highest quality)
# OPENAI_API_KEY="your-openai-api-key-here"

# ============================================
# STRIPE PAYMENT CONFIGURATION
# ============================================
# Get these from https://dashboard.stripe.com/apikeys
# Test keys (no real charges):
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_test_webhook_secret"

# Price IDs from Stripe Products
STRIPE_PRICE_ID_BASIC="price_test_basic_monthly"
STRIPE_PRICE_ID_PRO="price_test_pro_monthly"
STRIPE_PRICE_ID_ENTERPRISE="price_test_enterprise_monthly"

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV="production"
FRONTEND_URL="https://yourdomain.com"
BACKEND_URL="https://api.yourdomain.com"

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# CRITICAL: This must be your production backend URL
NEXT_PUBLIC_API_URL="https://api.yourdomain.com"

# ============================================
# RATE LIMITING (Security)
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="FitAI Pro <noreply@yourdomain.com>"

# ============================================
# AWS S3 (Optional - for file uploads)
# ============================================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME=""
AWS_REGION="us-east-1"

# ============================================
# ANALYTICS (Optional)
# ============================================
# Google Analytics, Mixpanel, etc. can be added here
