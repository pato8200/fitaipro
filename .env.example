# Database - PostgreSQL (Production-ready)
# For local dev: Install PostgreSQL or use Docker
# Alternative: Use free tier at https://neon.tech or https://supabase.com
DATABASE_URL="postgresql://user:password@localhost:5432/fitai-pro?sslmode=disable"

# JWT Secrets - GENERATE NEW SECURE RANDOM STRINGS FOR PRODUCTION!
# Use: openssl rand -hex 32
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-minimum-32-chars"

# AI Configuration
# Option 1: Use Ollama (FREE, local LLM) - Recommended for development
USE_OLLAMA=true
OLLAMA_BASE_URL="http://localhost:11434"

# Option 2: Use Hugging Face (has free tier)
HUGGINGFACE_API_KEY="your-huggingface-api-key-here"

# Stripe (Get keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"
STRIPE_PRICE_ID_BASIC="price_basic_tier_id"
STRIPE_PRICE_ID_PRO="price_pro_tier_id"
STRIPE_PRICE_ID_ENTERPRISE="price_enterprise_tier_id"

# Server Configuration
PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# Frontend Public API URL (used by client-side code)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Email Configuration (optional - for password reset, verification)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="FitAI Pro <noreply@fitaipro.com>"

# AWS S3 (optional - for file uploads)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_BUCKET_NAME=""
AWS_REGION="us-east-1"

# Rate Limiting (requests per minute)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_TIMEOUT=86400000
REFRESH_TOKEN_EXPIRY=7d
ACCESS_TOKEN_EXPIRY=15m
